getgenv().AntiLag = true

local effectClasses = {
    ParticleEmitter = true,
    Trail = false,
    Beam = true,
    Smoke = true,
    Fire = true,
    Sparkles = true,
    Explosion = true,
    Highlight = false
}

local function destroyIfEffect(obj)
    if getgenv().AntiLag and effectClasses[obj.ClassName] then
        obj:Destroy()
    end
end

game.DescendantAdded:Connect(function(descendant)
    if getgenv().AntiLag then
        task.defer(function()
            destroyIfEffect(descendant)
        end)
    end
end)

task.spawn(function()
    while true do
        if getgenv().AntiLag then
            local allDescendants = game:GetDescendants()
            for i = 1, #allDescendants do
                if not getgenv().AntiLag then break end
                
                destroyIfEffect(allDescendants[i])
                
                if i % 500 == 0 then
                    task.wait()
                end
            end
        end
        task.wait(0.5)
    end
end)
