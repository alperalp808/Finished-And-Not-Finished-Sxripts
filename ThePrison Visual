local function getFormattedName(player)
    return getgenv().NameType == "DisplayName" and player.DisplayName or player.Name
end

local function getPlayerRole(player)
    if player.Team then
        local teamName = player.Team.Name:lower()
        if teamName:find("warden") then return "Warden", getgenv().WardenColor end
        if teamName:find("guard") then return "Guard", getgenv().GuardColor end
        if teamName:find("inmate") or teamName:find("prisoner") then return "Inmate", getgenv().InmateColor end
        if teamName:find("medic") then return "Medic", getgenv().MedicColor end
        if teamName:find("operator") then return "Operator", getgenv().OperatorColor end
    end
    
    local leaderstats = player:FindFirstChild("leaderstats") or player:FindFirstChild("PlayerGui")
    if leaderstats then
        for _, val in pairs(leaderstats:GetDescendants()) do
            if val:IsA("StringValue") then
                local txt = val.Value:lower()
                if txt:find("warden") then return "Warden", getgenv().WardenColor end
                if txt:find("guard") then return "Guard", getgenv().GuardColor end
                if txt:find("inmate") or txt:find("prisoner") then return "Inmate", getgenv().InmateColor end
                if txt:find("medic") then return "Medic", getgenv().MedicColor end
                if txt:find("operator") then return "Operator", getgenv().OperatorColor end
            end
        end
    end
    return nil, nil
end

local function walkTo(humanoid, targetPos)
	humanoid:MoveTo(targetPos)
	local reached = false
	local connection
	
	connection = humanoid.MoveToFinished:Connect(function()
		reached = true
	end)
	
	local startTime = tick()
	repeat 
		task.wait(0.1) 
	until reached or (tick() - startTime) > 15
	if connection then connection:Disconnect() end
end

