local function isPlayerInAllowedTeam(player)
    if not player.Team then return false end
    for _, teamName in ipairs(getgenv().HealTeams or {}) do
        if player.Team.Name == teamName then
            return true
        end
    end
    return false
end

task.spawn(function()
    while true do
        task.wait(1)
        if getgenv().OtoHeal then
            local myCharacter = LocalPlayer.Character
            if myCharacter and (myCharacter:FindFirstChild("Bandage") or LocalPlayer:FindFirstChild("Backpack"):FindFirstChild("Bandage")) then
                for _, player in ipairs(Players:GetPlayers()) do
                    if player ~= LocalPlayer and isPlayerInAllowedTeam(player) then
                        local character = player.Character
                        local humanoid = character and character:FindFirstChildOfClass("Humanoid")
                        if humanoid and humanoid.Health > 0 and humanoid.Health < humanoid.MaxHealth then
                            pcall(function()
                                if ClientFunctions and ClientFunctions.ItemService and ClientFunctions.ItemService.healOther then
                                    ClientFunctions.ItemService.healOther:invokeWithTimeout(5000, humanoid)
                                end
                            end)
                        end
                    end
                end
            end
        end
    end
end)