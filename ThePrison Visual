local function updateESP(player)
    if player == LocalPlayer then return end
    
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") or not char:FindFirstChild("Humanoid") then
        removeESP(player)
        return
    end
    
    local role, roleColor = getPlayerRole(player)
    if not role then
        removeESP(player)
        return
    end
    
    local isNameEnabled = getgenv()[role:lower() .. "Name"]
    local isDistanceEnabled = getgenv()[role:lower() .. "Distance"] and isNameEnabled
    local isHighlightEnabled = getgenv()[role:lower() .. "Highlight"]
    
    local pFolder = storage:FindFirstChild(player.Name) or Instance.new("Folder", storage)
    pFolder.Name = player.Name
    
    local hl = pFolder:FindFirstChildOfClass("Highlight")
    if isHighlightEnabled then
        if not hl then hl = Instance.new("Highlight", pFolder) end
        hl.Adornee = char
        hl.FillColor = roleColor
        hl.OutlineColor = roleColor
        hl.FillTransparency = 1 - getgenv().highlightFillOpacity
        hl.OutlineTransparency = 1 - getgenv().highlightOutlineOpacity
        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    else
        if hl then hl:Destroy() end
    end
    
    local bbGui = pFolder:FindFirstChildOfClass("BillboardGui")
    if isNameEnabled then
        if not bbGui then
            bbGui = Instance.new("BillboardGui", pFolder)
            bbGui.AlwaysOnTop = true
            bbGui.Size = UDim2.new(0, 300, 0, 50)
            bbGui.StudsOffset = Vector3.new(0, 3.5, 0)
            
            local textLabel = Instance.new("TextLabel", bbGui)
            textLabel.Name = "EspText"
            textLabel.BackgroundTransparency = 1
            textLabel.Size = UDim2.new(1, 0, 1, 0)
            textLabel.Font = Enum.Font.SourceSansBold
            textLabel.TextStrokeTransparency = 0
            textLabel.TextStrokeColor3 = Color3.fromRGB(0,0,0)
        end
        
        local myChar = LocalPlayer.Character
        local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
        local targetRoot = char:FindFirstChild("HumanoidRootPart")
        
        bbGui.Adornee = targetRoot
        local textLabel = bbGui.EspText
        textLabel.TextSize = getgenv().nameSize
        textLabel.TextColor3 = roleColor
        
        local nameToShow = getFormattedName(player)
        if isDistanceEnabled and myRoot and targetRoot then
            local distance = math.floor((myRoot.Position - targetRoot.Position).Magnitude)
            textLabel.Text = string.format("%s [%d studs]", nameToShow, distance)
        else
            textLabel.Text = nameToShow
        end
    else
        if bbGui then bbGui:Destroy() end
    end
end

local function startDoorOpener()
