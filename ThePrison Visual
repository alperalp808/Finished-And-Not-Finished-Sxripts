	local function createToggle(parent, labelText, settingName)
		local container = Instance.new("Frame")
		container.Name = labelText
		container.BackgroundTransparency = 1
		container.Size = UDim2.new(1, 0, 0, 30)
		container.Parent = parent

		local label = Instance.new("TextLabel")
		label.BackgroundTransparency = 1
		label.Size = UDim2.new(1, -40, 1, 0)
		label.Font = Enum.Font.Gotham
		label.TextSize = 12
		label.TextColor3 = Color3.fromRGB(200, 200, 200)
		label.Text = labelText
		label.TextXAlignment = Enum.TextXAlignment.Left
		label.Parent = container

		local toggleButton = Instance.new("TextButton")
		toggleButton.Name = "Toggle"
		toggleButton.BackgroundColor3 = getgenv()[settingName] and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(150, 0, 0)
		toggleButton.BackgroundTransparency = 0.3
		toggleButton.BorderSizePixel = 0
		toggleButton.Size = UDim2.new(0, 35, 0, 25)
		toggleButton.Position = UDim2.new(1, -35, 0.5, -12.5)
		toggleButton.Font = Enum.Font.GothamBold
		toggleButton.TextSize = 10
		toggleButton.TextColor3 = Color3.fromRGB(255, 255, 255)
		toggleButton.Text = getgenv()[settingName] and "ON" or "OFF"
		toggleButton.Parent = container

		local toggleCorner = Instance.new("UICorner")
		toggleCorner.CornerRadius = UDim.new(0, 4)
		toggleCorner.Parent = toggleButton

		toggleButton.MouseButton1Click:Connect(function()
			getgenv()[settingName] = not getgenv()[settingName]
			toggleButton.BackgroundColor3 = getgenv()[settingName] and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(150, 0, 0)
