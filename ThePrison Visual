	local minusCorner = Instance.new("UICorner")
	minusCorner.CornerRadius = UDim.new(0, 4)
	minusCorner.Parent = minusButton

	local plusButton = Instance.new("TextButton")
	plusButton.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
	plusButton.BackgroundTransparency = 0.3
	plusButton.BorderSizePixel = 0
	plusButton.Size = UDim2.new(0, 30, 1, 0)
	plusButton.Position = UDim2.new(1, -30, 0, 0)
	plusButton.Font = Enum.Font.GothamBold
	plusButton.TextSize = 12
	plusButton.TextColor3 = Color3.fromRGB(255, 255, 255)
	plusButton.Text = "+"
	plusButton.Parent = sliderContainer

	local plusCorner = Instance.new("UICorner")
	plusCorner.CornerRadius = UDim.new(0, 4)
	plusCorner.Parent = plusButton

	minusButton.MouseButton1Click:Connect(function()
		getgenv().NameTextSize = math.max(8, getgenv().NameTextSize - 2)
		sizeLabel.Text = "Yazı Boyutu: " .. getgenv().NameTextSize
		sizeValue.Text = getgenv().NameTextSize
	end)

	plusButton.MouseButton1Click:Connect(function()
		getgenv().NameTextSize = math.min(32, getgenv().NameTextSize + 2)
		sizeLabel.Text = "Yazı Boyutu: " .. getgenv().NameTextSize
		sizeValue.Text = getgenv().NameTextSize
	end)

	--// HIDE/SHOW FUNCTIONALITY
	local isHidden = false
	hideButton.MouseButton1Click:Connect(function()
		isHidden = not isHidden
		scrollFrame.Visible = not isHidden
		headerFrame.Size = isHidden and UDim2.new(1, 0, 1, 0) or UDim2.new(1, 0, 0, 35)
		mainFrame.Size = isHidden and UDim2.new(0, 250, 0, 35) or UDim2.new(0, 250, 0, 400)
		hideButton.Text = isHidden and "⬆" or "━"
	end)

	--// DRAG FUNCTIONALITY
	local dragging = false
	local dragStart = nil
	local frameStart = nil

	local function onInputBegan(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			if UserInputService:GetMouseLocation().X >= mainFrame.AbsolutePosition.X and
				UserInputService:GetMouseLocation().X <= mainFrame.AbsolutePosition.X + mainFrame.AbsoluteSize.X and
				UserInputService:GetMouseLocation().Y >= mainFrame.AbsolutePosition.Y and
				UserInputService:GetMouseLocation().Y <= mainFrame.AbsolutePosition.Y + 35 then
				dragging = true
				dragStart = UserInputService:GetMouseLocation()
				frameStart = mainFrame.Position
			end
		end
	end

	local function onInputChanged()
		if dragging and dragStart and frameStart then
			local currentMouse = UserInputService:GetMouseLocation()
			local delta = currentMouse - dragStart
			mainFrame.Position = frameStart + UDim2.new(0, delta.X, 0, delta.Y)
		end
	end

	local function onInputEnded(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
			dragStart = nil
			frameStart = nil
			getgenv().MenuPosition = mainFrame.Position
		end
	end

	UserInputService.InputBegan:Connect(onInputBegan)
	UserInputService.InputChanged:Connect(onInputChanged)
	UserInputService.InputEnded:Connect(onInputEnded)

	--// VISIBILITY TOGGLE (V tuşu)
	UserInputService.InputBegan:Connect(function(input, gameProcessed)
		if gameProcessed then return end
		if input.KeyCode == Enum.KeyCode.V then
			getgenv().MenuVisible = not getgenv().MenuVisible
			mainFrame.Visible = getgenv().MenuVisible
		end
	end)

	return screenGui
end

--// ESP SISTEM

local function getRole(plr)
	return plr.Team and plr.Team.Name or nil
end

local function getSettings(role)
	if role == "Inmate" then
		return getgenv().InmateHighlight, getgenv().InmateText
	elseif role == "Guard" then
		return getgenv().GuardHighlight, getgenv().GuardText
	elseif role == "Warden" then
		return getgenv().WardenHighlight, getgenv().WardenText
	elseif role == "Operator" then
		return getgenv().OperatorHighlight, getgenv().OperatorText
	end

	return false,false
end

local function updatePlayer(plr)
	if plr == LocalPlayer then
		return
	end

	local character = plr.Character
	if not character then
		return
	end

	local head = character:FindFirstChild("Head")
	if not head then
		return
	end

	local role = getRole(plr)
	local color = ROLE_COLORS[role]

	if not color then
		return
	end

	local highlightEnabled,textEnabled = getSettings(role)

	--// HIGHLIGHT
	local highlight = character:FindFirstChild("RoleESP")

	if highlightEnabled then
		if not highlight then
			highlight = Instance.new("Highlight")
			highlight.Name = "RoleESP"
			highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
			highlight.Parent = character
		end

		highlight.FillColor = color
		highlight.OutlineColor = Color3.new(1,1,1)
		highlight.FillTransparency = 0.35
		highlight.OutlineTransparency = 0
	else
		if highlight then
			highlight:Destroy()
		end
	end

	--// NAME ESP
	local billboard = head:FindFirstChild("RoleNameESP")

	if textEnabled then
		if not billboard then
			billboard = Instance.new("BillboardGui")
			billboard.Name = "RoleNameESP"
			billboard.Parent = head
			billboard.Adornee = head
			billboard.AlwaysOnTop = true
			billboard.LightInfluence = 0
			billboard.MaxDistance = math.huge
			billboard.Size = UDim2.fromOffset(200,40)
			billboard.StudsOffset = Vector3.new(0,2.5,0)

			local text = Instance.new("TextLabel")
			text.Name = "Name"
			text.BackgroundTransparency = 1
			text.Size = UDim2.fromScale(1,1)
			text.Font = Enum.Font.GothamBold
			text.TextStrokeTransparency = 0
			text.TextScaled = false
			text.Parent = billboard
		end

		local label = billboard:FindFirstChild("Name")

		if label then
			label.Text = plr.DisplayName
			label.TextColor3 = color
			label.TextSize = getgenv().NameTextSize
		end
	else
		if billboard then
			billboard:Destroy()
		end
	end
end

local function setupPlayer(plr)

	local function characterAdded(char)
		task.wait(0.5)

		updatePlayer(plr)

		char.ChildAdded:Connect(function()
			task.defer(updatePlayer,plr)
		end)
	end

	if plr.Character then
		task.spawn(characterAdded,plr.Character)
	end

	plr.CharacterAdded:Connect(characterAdded)

	plr:GetPropertyChangedSignal("Team"):Connect(function()
		task.defer(updatePlayer,plr)
	end)

	plr:GetPropertyChangedSignal("DisplayName"):Connect(function()
		task.defer(updatePlayer,plr)
	end)
end

for _,plr in ipairs(Players:GetPlayers()) do
	setupPlayer(plr)
end

Players.PlayerAdded:Connect(setupPlayer)

--// MENU BAŞLAT
local menuGui = createMenuUI()

--// LIVE UPDATE LOOP
RunService.RenderStepped:Connect(function()

	for _,plr in ipairs(Players:GetPlayers()) do
		updatePlayer(plr)
	end

end)