local function updateEffects(targetHRP, myHRP)
    if not getgenv().MarkTarget or not targetHRP or not myHRP then
        if markerPart then markerPart:Destroy() markerPart = nil end
        if targetBeam then targetBeam:Destroy() targetBeam = nil end
        if markerAttachment then markerAttachment:Destroy() markerAttachment = nil end
        if myAttachment then myAttachment:Destroy() myAttachment = nil end
        return
    end
    
    local targetVelocity = targetHRP.Velocity
    local predictionOffset = targetVelocity * 0.13
    local predictedPosition = targetHRP.Position + predictionOffset
    
    if not markerPart or not markerPart.Parent then
        markerPart = Instance.new("Part")
        markerPart.Size = Vector3.new(3, 5, 3)
        markerPart.Shape = Enum.PartType.Block
        markerPart.Material = Enum.Material.ForceField
        markerPart.Color = Color3.fromRGB(255, 0, 0)
        markerPart.Transparency = 0.7
        markerPart.CanCollide = false
        markerPart.Anchored = false
        markerPart.Massless = true
        markerPart.Parent = effectFolder
        
        local alignPos = Instance.new("AlignPosition")
        alignPos.MaxForce = 999999
        alignPos.Responsiveness = 50
        alignPos.Mode = Enum.PositionAlignmentMode.OneAttachment
        
        markerAttachment = Instance.new("Attachment", markerPart)
        alignPos.Attachment0 = markerAttachment
        alignPos.Parent = markerPart
        markerPart.Position = predictedPosition
    end
    
    if not targetBeam or not targetBeam.Parent then
        myAttachment = Instance.new("Attachment", myHRP)
        targetBeam = Instance.new("Beam")
        targetBeam.Attachment0 = myAttachment
        targetBeam.Attachment1 = markerAttachment
        targetBeam.Width0 = 0.2
        targetBeam.Width1 = 0.2
        targetBeam.Color = ColorSequence.new(Color3.fromRGB(255, 0, 0))
        targetBeam.Transparency = NumberSequence.new(0.5)
        targetBeam.FaceCamera = true
        targetBeam.Parent = effectFolder
    end
    
    if markerPart and markerPart:FindFirstChild("AlignPosition") then
        markerPart.AlignPosition.Position = predictedPosition
        markerPart.CFrame = targetHRP.CFrame + predictionOffset
    end
end

