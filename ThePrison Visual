--// ESP SYSTEM ENGINE

local function getRole(plr)
	return plr.Team and plr.Team.Name or nil
end

local function getSettings(role)
	if role == "Inmate" then return getgenv().InmateHighlight, getgenv().InmateText
	elseif role == "Guard" then return getgenv().GuardHighlight, getgenv().GuardText
	elseif role == "Warden" then return getgenv().WardenHighlight, getgenv().WardenText
	elseif role == "Operator" then return getgenv().OperatorHighlight, getgenv().OperatorText
	end
	return false, false
end

local function updatePlayer(plr)
	if plr == LocalPlayer then return end

	local character = plr.Character
	if not character then return end

	local head = character:FindFirstChild("Head")
	local hrp = character:FindFirstChild("HumanoidRootPart")
	local humanoid = character:FindFirstChildOfClass("Humanoid")
	
	if not head or not hrp or not humanoid or humanoid.Health <= 0 then 
		if character:FindFirstChild("RoleESP") then character.RoleESP:Destroy() end
		if head and head:FindFirstChild("RoleNameESP") then head.RoleNameESP:Destroy() end
		if hrp and hrp:FindFirstChild("RoleHealthESP") then hrp.RoleHealthESP:Destroy() end
		return 
	end

	local role = getRole(plr)
	local color = ROLE_COLORS[role]

	if not color then
		if character:FindFirstChild("RoleESP") then character.RoleESP:Destroy() end
		if head:FindFirstChild("RoleNameESP") then head.RoleNameESP:Destroy() end
		if hrp:FindFirstChild("RoleHealthESP") then hrp.RoleHealthESP:Destroy() end
		return
	end

	local highlightEnabled, textEnabled = getSettings(role)

	--// HIGHLIGHT GÜNCELLEME
	local highlight = character:FindFirstChild("RoleESP")
	if highlightEnabled then
		if not highlight then
			highlight = Instance.new("Highlight")
			highlight.Name = "RoleESP"
			highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
			highlight.Parent = character
		end
		highlight.FillColor = color
		highlight.OutlineColor = Color3.new(1, 1, 1)
		highlight.FillTransparency = 0.4
		highlight.OutlineTransparency = 0
	else
		if highlight then highlight:Destroy() end
	end

	--// NAME & DISTANCE
	local billboard = head:FindFirstChild("RoleNameESP")
	if textEnabled then
		if not billboard then
			billboard = Instance.new("BillboardGui")
			billboard.Name = "RoleNameESP"
			billboard.Parent = head
			billboard.Adornee = head
			billboard.AlwaysOnTop = true
			billboard.LightInfluence = 0
			billboard.MaxDistance = 3500
			billboard.Size = UDim2.fromOffset(250, 30)
			billboard.StudsOffset = Vector3.new(0, 1.8, 0)

			local textLabel = Instance.new("TextLabel")
			textLabel.Name = "InfoLabel"
			textLabel.BackgroundTransparency = 1
			textLabel.Size = UDim2.fromScale(1, 1)
			textLabel.Font = Enum.Font.GothamBold
			textLabel.TextStrokeTransparency = 0
			textLabel.TextStrokeColor3 = Color3.new(0, 0, 0)
			textLabel.Parent = billboard
		end

		local infoLabel = billboard:FindFirstChild("InfoLabel")
		if infoLabel then
			if getgenv().ShowDistance then
				local distance = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") and 
					math.floor((LocalPlayer.Character.HumanoidRootPart.Position - hrp.Position).Magnitude) or 0
				infoLabel.Text = string.format("%s [%s Stud]", plr.DisplayName, distance)
			else
				infoLabel.Text = plr.DisplayName
			end
			infoLabel.TextColor3 = color
			infoLabel.TextSize = getgenv().NameTextSize
		end
	else
		if billboard then billboard:Destroy() end
	end

	--// DIKEY SAĞLIK BAR SİSTEMİ
	local healthBillboard = hrp:FindFirstChild("RoleHealthESP")
	if textEnabled and getgenv().ShowHealthBar then
		if not healthBillboard then
			healthBillboard = Instance.new("BillboardGui")
			healthBillboard.Name = "RoleHealthESP"
			healthBillboard.Parent = hrp
			healthBillboard.Adornee = hrp
			healthBillboard.AlwaysOnTop = true
			healthBillboard.LightInfluence = 0
			healthBillboard.MaxDistance = 5000
			healthBillboard.Size = UDim2.new(0.2, 0, 4.5, 0) 
			healthBillboard.StudsOffset = Vector3.new(2.2, 0, 0)

			local healthBG = Instance.new("Frame")
			healthBG.Name = "HealthBG"
			healthBG.BackgroundColor3 = Color3.fromRGB(40, 0, 0)
			healthBG.BorderSizePixel = 0
			healthBG.Size = UDim2.new(0.25, 0, 0.9, 0) 
			healthBG.Position = UDim2.new(0.5, -2, 0.05, 0)
			healthBG.Parent = healthBillboard

			local aspectRatio = Instance.new("UIAspectRatioConstraint")
			aspectRatio.AspectRatio = 0.06
			aspectRatio.DominantAxis = Enum.DominantAxis.Height
			aspectRatio.Parent = healthBG

			local sizeConstraint = Instance.new("UISizeConstraint")
			sizeConstraint.MinSize = Vector2.new(3, 30)
			sizeConstraint.Parent = healthBG

			local healthMain = Instance.new("Frame")
			healthMain.Name = "HealthMain"
			healthMain.BorderSizePixel = 0
			healthMain.Position = UDim2.new(0, 0, 1, 0) 
			healthMain.Size = UDim2.new(1, 0, 0, 0)
			healthMain.Parent = healthBG
		end

		local healthBG = healthBillboard:FindFirstChild("HealthBG")
		local healthMain = healthBG and healthBG:FindFirstChild("HealthMain")

		if healthMain and healthBG then
			healthBG.Visible = true
			local healthRatio = math.clamp(humanoid.Health / humanoid.MaxHealth, 0, 1)
			healthMain.Size = UDim2.new(1, 0, healthRatio, 0)
			healthMain.Position = UDim2.new(0, 0, 1 - healthRatio, 0)
			healthMain.BackgroundColor3 = Color3.fromRGB(255 - (healthRatio * 255), healthRatio * 255, 0)
		end
	else
		if healthBillboard then healthBillboard:Destroy() end
	end
end

--// EVENT LISTENER SETUP
local function setupPlayer(plr)
	local function characterAdded(char)
		char:WaitForChild("Head", 10)
		char:WaitForChild("HumanoidRootPart", 10)
		char:WaitForChild("Humanoid", 10)
		task.wait(0.4)
		updatePlayer(plr)

		char.ChildAdded:Connect(function() task.defer(updatePlayer, plr) end)
	end

	if plr.Character then task.spawn(characterAdded, plr.Character) end
	plr.CharacterAdded:Connect(characterAdded)

	plr:GetPropertyChangedSignal("Team"):Connect(function() task.defer(updatePlayer, plr) end)
	plr:GetPropertyChangedSignal("DisplayName"):Connect(function() task.defer(updatePlayer, plr) end)
end

--// INITIALIZE
for _, plr in ipairs(Players:GetPlayers()) do setupPlayer(plr) end
Players.PlayerAdded:Connect(setupPlayer)

local menuGui = createMenuUI()

--// LIVE RENDER LOOP
RunService.RenderStepped:Connect(function()
	for _, plr in ipairs(Players:GetPlayers()) do
		updatePlayer(plr)
	end
end)
