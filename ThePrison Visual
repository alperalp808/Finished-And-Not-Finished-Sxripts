	--// SIZE SLIDER
	local sliderContainer = Instance.new("Frame")
	sliderContainer.BackgroundTransparency = 1
	sliderContainer.Size = UDim2.new(1, 0, 0, 25)
	sliderContainer.Parent = sizeContainer

	local minusButton = Instance.new("TextButton")
