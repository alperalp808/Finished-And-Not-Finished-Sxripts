                            task.wait(0.02)
                        end
                    end
                end
            end
        end
    end)
end

local function startPhaseSystem()
    task.spawn(function()
        local cachedTargets = {}
        local originalCollisions = {}
        
        local function addPartToCache(part)
            if part and part:IsA("BasePart") and not table.find(cachedTargets, part) then
                table.insert(cachedTargets, part)
                originalCollisions[part] = part.CanCollide
            end
        end
        
        local doorsContainer = Workspace:FindFirstChild("Doors")
        if doorsContainer then
            for _, door in ipairs(doorsContainer:GetDescendants()) do addPartToCache(door) end
        end

        local scriptables = Workspace:FindFirstChild("Scriptables")
        local checkpoints = scriptables and scriptables:FindFirstChild("Checkpoints")
        local eliteCollider = checkpoints and checkpoints:FindFirstChild("EliteCollider")
        if eliteCollider then
            if eliteCollider:IsA("BasePart") then addPartToCache(eliteCollider) else
                for _, p in ipairs(eliteCollider:GetDescendants()) do addPartToCache(p) end
            end
        end
        
        for _, obj in ipairs(Workspace:GetDescendants()) do
            if obj.Name == "GuardCollider" then addPartToCache(obj) end
        end

        while true do
            task.wait(0.3)
            if getgenv().PhaseDoors then
                for _, part in ipairs(cachedTargets) do
                    if part and part.Parent and part.CanCollide then
                        part.CanCollide = false
                    end
                end
            else
                for part, originalState in pairs(originalCollisions) do
                    if part and part.Parent and part.CanCollide ~= originalState then
                        part.CanCollide = originalState
                    end
                end
            end
        end
    end)
end

startDoorOpener()
