local zigzagDirection, lastZigzagTime = 1, 0
local function walkToTarget(targetPos)
    while getgenv().OtoEscape do
        local char, hrp, hum = getCharacterData()
        if not hum or not hrp or hum.Health <= 0 then return false end
        
        local currentPos = hrp.Position
        local distanceVector = targetPos - currentPos
        local flatDistance = Vector2.new(distanceVector.X, distanceVector.Z).Magnitude
        if flatDistance <= 4.5 then return true end
        
        local finalDestination = targetPos
        if isFirstWaypointReached and getgenv().dodge and flatDistance > 12 then
            if os.clock() - lastZigzagTime > 0.7 then zigzagDirection = -zigzagDirection; lastZigzagTime = os.clock() end
            local forwardUnit = Vector3.new(distanceVector.X, 0, distanceVector.Z).Unit
            local rightUnit = Vector3.new(-forwardUnit.Z, 0, forwardUnit.X)
            local rangePercent = math.clamp(getgenv().Range or 10, 0, 100)
            local maxAngleRad = math.rad((rangePercent / 100) * 90)
            local finalOffsetLength = math.clamp(math.sin(maxAngleRad) * flatDistance, 2, 45)
            finalDestination = targetPos + (rightUnit * (zigzagDirection * finalOffsetLength))
        end
        hum:MoveTo(finalDestination)
        task.wait(0.05)
    end
    return false
end

