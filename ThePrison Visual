local function killPlayer(char)
    if not getgenv().RagdollToDeath then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum and hum.Health > 0 then hum.Health = 0 end
end

local function listenNetworkEvents()
    if not getgenv().RagdollToDeath then return end
    local success, netHelper = pcall(function()
        return require(ReplicatedStorage:WaitForChild("TS"):WaitForChild("utils"):WaitForChild("network.helper"))
    end)
    if success and netHelper and netHelper.ClientEvents then
        local notifyRagdollEvent = netHelper.ClientEvents.Effects and netHelper.ClientEvents.Effects.notifyRagdoll
        if notifyRagdollEvent then
            local oldConnect = notifyRagdollEvent.connect or notifyRagdollEvent.Connect
            local hookFunction = function(self, callback)
                return oldConnect(self, function(...)
                    if getgenv().RagdollToDeath then
                        task.spawn(function()
                            local char, _, _ = getCharacterData()
                            if char then killPlayer(char) end
                        end)
                    end
                    return callback(...)
                end)
            end
            if notifyRagdollEvent.connect then notifyRagdollEvent.connect = hookFunction end
            if notifyRagdollEvent.Connect then notifyRagdollEvent.Connect = hookFunction end
        end
    end
end

local function setupCharacter(char)
    task.spawn(listenNetworkEvents)
    local hum = char:WaitForChild("Humanoid", 5)
    if not hum then return end
    
    hum.StateChanged:Connect(function(_, newState)
        if getgenv().RagdollToDeath and char.Parent then 
            if newState == Enum.HumanoidStateType.Physics or newState == Enum.HumanoidStateType.Ragdoll or newState == Enum.HumanoidStateType.FallingDown then
                killPlayer(char)
            end
        end
    end)
end

